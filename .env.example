# Required — Get this from https://app.dynamic.xyz
VITE_DYNAMIC_ENVIRONMENT_ID=

# Altude API Keys — Get these from https://dashboard.altude.so
# Set one or both depending on which networks you want to use
VITE_ALTUDE_API_KEY_DEVNET=
VITE_ALTUDE_API_KEY_MAINNET=

# Optional — SPL token mint address for ATA creation + send transaction
# If set, the Create Transaction step will also create an ATA for this mint,
# and the Send Transaction button will be enabled.
VITE_TOKEN_MINT=
